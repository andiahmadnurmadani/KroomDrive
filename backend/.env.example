# Copy this file to .env and fill in your values
# cp .env.example .env

# Backend port
PORT=4344

# JWT — CHANGE THIS to a random secret in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# Database file location (relative to backend/ dir, or absolute path)
DB_PATH=./data/kroomdrive.db

# Temp directory for file uploads
UPLOAD_TEMP_DIR=./data/uploads

# CORS allowed origins (comma-separated, or * for all)
# Production example: CORS_ORIGIN=https://yourdomain.com
CORS_ORIGIN=*

# Default admin account (only used on FIRST RUN, when no admin exists in DB)
# CHANGE ADMIN_PASSWORD before first run in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
